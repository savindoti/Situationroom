rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ==== GLOBAL SAFETY NET ====
    match /{document=**} {
      allow read, write: if false;
    }

    // ==== PRIMITIVES ====
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    
    // RBAC Helpers
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    function getRole() {
      return getUserData().role;
    }
    function isSuperAdmin() {
      return isSignedIn() && (getRole() == 'SUPERADMIN' || request.auth.token.email == 'shrestha.nibas@gmail.com');
    }
    function isAdmin() {
      return isSignedIn() && getRole() == 'ADMIN';
    }
    function isLocalUser() {
      return isSignedIn() && getRole() == 'LOCAL_USER';
    }
    function hasWritePermission() {
      return isSuperAdmin() || isAdmin();
    }

    // ==== VALIDATION BLUEPRINTS ====
    function isValidSupportTask(data) {
      return data.keys().hasAll([
        'date', 'province', 'district', 'municipal', 'details', 
        'organization', 'contactPerson', 'contactNumber', 'status', 
        'createdAt', 'updatedAt', 'ownerId'
      ]) 
      && data.keys().hasOnly([
        'date', 'province', 'district', 'municipal', 'details', 
        'organization', 'contactPerson', 'contactNumber', 'status', 
        'createdAt', 'updatedAt', 'ownerId', 'ownerEmail', 'ownerName',
        'uploadedByEmail', 'lastUpdatedByEmail', 'lastUpdatedTimestamp'
      ])
      && data.date is string && data.date.size() <= 64
      && data.province is string && data.province.size() <= 128
      && data.district is string && data.district.size() <= 128
      && data.municipal is string && data.municipal.size() <= 128
      && data.details is string && data.details.size() <= 10000
      && data.organization is string && data.organization.size() <= 256
      && data.contactPerson is string && data.contactPerson.size() <= 256
      && data.contactNumber is string && data.contactNumber.size() <= 32
      && data.status in ['Pending', 'Ongoing', 'Resolved']
      && data.createdAt is int
      && data.updatedAt is int
      && data.ownerId == request.auth.uid
      && (data.get('uploadedByEmail', '') is string && data.get('uploadedByEmail', '').size() <= 256);
    }

    function isValidRiskArea(data) {
      return data.keys().hasAll([
        'province', 'district', 'municipal', 'wardNumber', 'disasterLocation',
        'lat', 'lng', 'typeOfDisaster', 'riskType', 'exposure',
        'previousDamageDetails', 'preparednessActions', 'remarks',
        'uploadedAt', 'uploaderId'
      ])
      && data.keys().hasOnly([
        'province', 'district', 'municipal', 'wardNumber', 'disasterLocation',
        'lat', 'lng', 'typeOfDisaster', 'riskType', 'exposure',
        'previousDamageDetails', 'preparednessActions', 'remarks',
        'uploadedAt', 'uploaderId', 'uploadedByEmail', 'lastUpdatedByEmail', 'lastUpdatedTimestamp'
      ])
      && data.province is string && data.province.size() <= 128
      && data.district is string && data.district.size() <= 128
      && data.municipal is string && data.municipal.size() <= 128
      && data.wardNumber is string && data.wardNumber.size() <= 32
      && data.disasterLocation is string && data.disasterLocation.size() <= 1024
      && (data.lat is number || data.lat is int || data.lat is float)
      && (data.lng is number || data.lng is int || data.lng is float)
      && data.typeOfDisaster is string && data.typeOfDisaster.size() <= 256
      && data.riskType in ['Low', 'Medium', 'High']
      && data.uploadedAt is int
      && data.uploaderId == request.auth.uid
      && (data.get('uploadedByEmail', '') is string && data.get('uploadedByEmail', '').size() <= 256);
    }

    function isValidUserUpdate(data) {
      return data.keys().hasOnly(['username', 'role', 'isDisabled', 'lastLogin'])
      && (data.get('role', 'LOCAL_USER') in ['SUPERADMIN', 'ADMIN', 'LOCAL_USER']);
    }

    // ==== PATHS ====
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSuperAdmin();
      // Users can update their own username and lastLogin
      // Only Superadmin can update roles or disable users
      allow update: if isSignedIn() && (
        (userId == request.auth.uid && incoming().keys().hasOnly(['username', 'lastLogin']))
        || isSuperAdmin()
      );
      // Only Superadmin can create or delete user profiles manually (though login usually handles creation)
      allow create: if isSuperAdmin() || (isSignedIn() && userId == request.auth.uid);
      allow delete: if isSuperAdmin();
    }

    match /risk_areas/{areaId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && hasWritePermission() && isValidRiskArea(incoming());
      allow update: if isSignedIn() && hasWritePermission() && (
        isSuperAdmin() || (isAdmin() && existing().uploaderId == request.auth.uid)
      ) && isValidRiskArea(incoming());
      allow delete: if isSignedIn() && hasWritePermission() && (
        isSuperAdmin() || (isAdmin() && existing().uploaderId == request.auth.uid)
      );
    }

    match /tasks/{taskId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && hasWritePermission() && isValidSupportTask(incoming());
      allow update: if isSignedIn() && hasWritePermission() && (
        isSuperAdmin() || (isAdmin() && existing().ownerId == request.auth.uid)
      ) && isValidSupportTask(incoming());
      allow delete: if isSignedIn() && hasWritePermission() && (
        isSuperAdmin() || (isAdmin() && existing().ownerId == request.auth.uid)
      );
    }
  }
}
